[sub_resource type="GDScript" id="GDScript_00tan"]
resource_name = "player"
script/source = "extends CharacterBody2D

var remainingCatnipTime: int = 0
var catnipMultiplier: int = 1
var climbingDivider: int = 1
var doinStuff: bool = true

func _physics_process(delta: float) -> void:
	
	if Input.is_action_pressed(\"interact\") && !$cup.get_overlapping_bodies().is_empty() && is_on_floor() && doinStuff == true:
		doinStuff = false
		var center_cell = $\"../cups\".local_to_map($\"../cups\".to_local(global_position))
		for x in range(-1, 2):
			for y in range(-1, 2):
					$\"../cups\".set_cell(center_cell + Vector2i(x, y), -1)
		$AnimatedSprite2D.play(\"cup interact\")
	
	if doinStuff == true :
		remainingCatnipTime -= int(delta * 1000)
		if remainingCatnipTime > 0:
			catnipMultiplier = 2
			$\"../Camera2D/catnipStatusEffect2\".visible = true
		else:
			catnipMultiplier = 1
			$\"../Camera2D/catnipStatusEffect2\".visible = false
		
		$\"../Camera2D/catnipStatusEffect\".modulate.a = clampf(float(remainingCatnipTime) / 10000, 0, 1.5)
		
		if !is_on_floor():
			velocity += get_gravity() * delta

		if Input.is_action_pressed(\"up\") && is_on_floor():
			velocity.y = -400  * catnipMultiplier

		if Input.is_action_pressed(\"up\") && !$climb.get_overlapping_bodies().is_empty():
			velocity.y = -100  * catnipMultiplier
			climbingDivider = 2
			if $AnimatedSprite2D.animation != \"climbing\":
				$AnimatedSprite2D.animation = \"climbing\"
		else:
			climbingDivider = 1

		var direction := Input.get_axis(\"left\", \"right\")
		if direction && Input.is_action_pressed(\"sprint\"):
			velocity.x = direction * 200 * 2 * catnipMultiplier / climbingDivider
			if $AnimatedSprite2D.animation != \"running\" && climbingDivider == 1:
				$AnimatedSprite2D.animation = \"running\"
		elif direction:
			velocity.x = direction * 200 * catnipMultiplier / climbingDivider
			if $AnimatedSprite2D.animation != \"walking\" && climbingDivider == 1:
				$AnimatedSprite2D.animation = \"walking\"
		else:
			velocity.x = move_toward(velocity.x, 0, 200 * catnipMultiplier)
			if ($AnimatedSprite2D.animation != \"blinking\") && (!Input.is_action_pressed(\"up\")):
				$AnimatedSprite2D.animation = \"blinking\"
	
		if direction < 0:
			$AnimatedSprite2D.flip_h = false
		elif direction > 0:
			$AnimatedSprite2D.flip_h = true

		move_and_slide()
	else :
		if !$AnimatedSprite2D.is_playing():
			doinStuff = true
			add_sibling(load(\"res://scenes/falling cup.tscn\").instantiate())
			$\"../FallingCup\".position.y = position.y + 64
			$\"../FallingCup\".startY = position.y
			$\"../FallingCup\".position.x = position.x + (int($AnimatedSprite2D.flip_h) * 100) - 50
			$\"../FallingCup/AnimatedSprite2D\".flip_h = $AnimatedSprite2D.flip_h

func _on_catnip_body_entered(_body: Node2D) -> void:
	remainingCatnipTime = remainingCatnipTime + 10000
	var center_cell = $\"../catnip\".local_to_map($\"../catnip\".to_local(global_position))
	for x in range(-1, 2):
		for y in range(-1, 2):
			$\"../catnip\".set_cell(center_cell + Vector2i(x, y), -1)
"

