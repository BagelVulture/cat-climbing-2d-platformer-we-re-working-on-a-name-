[sub_resource type="GDScript" id="GDScript_hbo4f"]
resource_name = "camera"
script/source = "extends Camera2D

func _process(delta: float) -> void:
	position += ($\"../CharacterBody2D\".position - position) / 0.2 * delta
	$\"../bg2\".position = position / 4
	$\"../bg2\".position.y -= 3584
"

